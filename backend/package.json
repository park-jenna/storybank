{
  "name": "prepository-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "prisma generate",
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:push": "node ./scripts/push-test-db.js",
    "test:prepare": "npm run test:db:up && npm run test:db:push",
    "test:local": "npm run test:prepare && npm test"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
