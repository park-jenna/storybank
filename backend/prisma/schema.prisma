generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  stories   Story[]
  questions Question[]
  createdAt DateTime   @default(now())
}

model Story {
  id     String   @id @default(uuid())
  userId String

  categories String[]

  situation String
  action    String
  result    String
  title     String

  createdAt    DateTime       @default(now())
  questionLinks QuestionStory[]
  user         User           @relation(fields: [userId], references: [id])
}

model Question {
  id                   String         @id @default(uuid())
  userId               String
  content              String
  recommendedCategories String[]

  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  stories   QuestionStory[]
}

model QuestionStory {
  id         String   @id @default(uuid())
  questionId String
  storyId    String

  createdAt DateTime @default(now())
  question  Question @relation(fields: [questionId], references: [id])
  story     Story    @relation(fields: [storyId], references: [id])
}
